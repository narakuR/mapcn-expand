{
  "$schema": "https://ui.shadcn.com/schema/registry.json",
  "name": "@naraku/mapcn-expand",
  "homepage": "https://mapcn-expand.vercel.app",
  "items": [
    {
      "name": "map",
      "type": "registry:ui",
      "title": "Map",
      "description": "A MapLibre-powered map component with markers, popups, tooltips, routes, and controls.",
      "dependencies": ["maplibre-gl", "lucide-react", "@mapbox/mapbox-gl-draw", "@turf/turf"],
      "devDependencies": ["@types/mapbox__mapbox-gl-draw"],
      "registryDependencies": [],
      "files": [
        {
          "path": "src/registry/map.tsx",
          "type": "registry:ui",
          "target": "components/ui/map.tsx"
        },
        {
          "path": "src/lib/map-draw/index.ts",
          "type": "registry:lib",
          "target": "lib/map-draw/index.ts"
        },
        {
          "path": "src/lib/map-draw/modes/CircleMode.ts",
          "type": "registry:lib",
          "target": "lib/map-draw/modes/CircleMode.ts"
        },
        {
          "path": "src/lib/map-draw/modes/DirectModeOverride.ts",
          "type": "registry:lib",
          "target": "lib/map-draw/modes/DirectModeOverride.ts"
        },
        {
          "path": "src/lib/map-draw/modes/RectangleMode.ts",
          "type": "registry:lib",
          "target": "lib/map-draw/modes/RectangleMode.ts"
        },
        {
          "path": "src/lib/map-draw/modes/SimpleSelectModeOverride.ts",
          "type": "registry:lib",
          "target": "lib/map-draw/modes/SimpleSelectModeOverride.ts"
        },
        {
          "path": "src/lib/map-draw/utils/createSupplementaryPointsForCircle.ts",
          "type": "registry:lib",
          "target": "lib/map-draw/utils/createSupplementaryPointsForCircle.ts"
        },
        {
          "path": "src/lib/map-draw/utils/drag_pan.ts",
          "type": "registry:lib",
          "target": "lib/map-draw/utils/drag_pan.ts"
        }
      ],
      "css": {
        "@layer base": {
          ".maplibregl-popup-content": {
             "@apply bg-transparent! shadow-none! p-0! rounded-none!": {}
          },
          ".maplibregl-popup-tip": {
            "@apply hidden!": {}
          }
        }
      }
    }
  ]
}
